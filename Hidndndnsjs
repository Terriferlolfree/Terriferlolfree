-- ── FUNCTIONS ────────────────────────────────

local function showToast(msg, color, duration)
    if toastTween then toastTween:Cancel() end
    toastLabel.Text = msg
    toastLabel.TextColor3 = color or Color3.fromRGB(100, 220, 130)
    toastFrame.BackgroundTransparency = 0.15
    toastTween = TweenService:Create(toastFrame, TweenInfo.new(duration or 3, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), { BackgroundTransparency = 1 })
    toastTween:Play()
    toastTween.Completed:Connect(function() toastLabel.Text = "" end)
end

local function findPlayer(name)
    local lower = name:lower()
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Name:lower() == lower or p.DisplayName:lower() == lower then return p end
    end
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Name:lower():find(lower, 1, true) or p.DisplayName:lower():find(lower, 1, true) then return p end
    end
    return nil
end

local function getRoot(player)
    local char = player and player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Head")
end

local function updateZoomHandle()
    local t = 1 - (viewState.zoom - viewState.minZoom) / (viewState.maxZoom - viewState.minZoom)
    local trackH = zoomTrack.AbsoluteSize.Y
    local trackY = zoomTrack.AbsolutePosition.Y - zoomBar.AbsolutePosition.Y
    zoomHandle.Position = UDim2.new(0.5, 0, 0, trackY + trackH * (1 - t) + 12)
end

local function getOrbitCFrame(origin)
    local yawCF   = CFrame.Angles(0, viewState.yaw, 0)
    local pitchCF = CFrame.Angles(viewState.pitch, 0, 0)
    local offset  = (yawCF * pitchCF) * Vector3.new(0, 0, viewState.zoom)
    return CFrame.new(origin + offset, origin)
end

local function stopViewing()
    if viewState.connection then viewState.connection:Disconnect(); viewState.connection = nil end
    viewState.target = nil
    camera.CameraType = Enum.CameraType.Custom
    local hum = localPlayer.Character and localPlayer.Character:FindFirstChildOfClass("Humanoid")
    if hum then camera.CameraSubject = hum end
    badge.Visible = false; zoomBar.Visible = false
    showToast("🔁 Camera restored", Color3.fromRGB(200, 200, 100))
end

local function startViewing(target)
    if viewState.connection then viewState.connection:Disconnect(); viewState.connection = nil end
    viewState.target = target; viewState.yaw = 0; viewState.pitch = math.rad(15)
    camera.CameraType = Enum.CameraType.Scriptable
    viewState.connection = RunService.RenderStepped:Connect(function()
        if not viewState.target or not viewState.target.Parent then stopViewing(); return end
        local root = getRoot(viewState.target)
        if root then camera.CFrame = getOrbitCFrame(root.Position + Vector3.new(0, 2, 0)) end
    end)
    badge.Visible = true; zoomBar.Visible = true
    badgeLabel.Text = "👁  VIEWING: " .. target.Name
    updateZoomHandle()
    showToast("👁 Now viewing " .. target.Name, Color3.fromRGB(80, 200, 255))
end

-- ── ZOOM SLIDER INPUT ────────────────────────
local sliderDragging = false
zoomHandle.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.Touch or inp.UserInputType == Enum.UserInputType.MouseButton1 then
        sliderDragging = true
    end
end)
UserInputService.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.Touch or inp.UserInputType == Enum.UserInputType.MouseButton1 then
        sliderDragging = false
    end
end)
UserInputService.InputChanged:Connect(function(inp)
    if sliderDragging and (inp.UserInputType == Enum.UserInputType.Touch or inp.UserInputType == Enum.UserInputType.MouseMove) then
        local posY = inp.Position.Y
        local trackTop    = zoomTrack.AbsolutePosition.Y
        local trackBottom = trackTop + zoomTrack.AbsoluteSize.Y
        local t = 1 - math.clamp((posY - trackTop) / (trackBottom - trackTop), 0, 1)
        viewState.zoom = viewState.minZoom + t * (viewState.maxZoom - viewState.minZoom)
        updateZoomHandle()
    end
end)

-- ── PC MOUSE ORBIT ───────────────────────────
UserInputService.InputBegan:Connect(function(inp, gp)
    if gp or not viewState.target then return end
    if inp.UserInputType == Enum.UserInputType.MouseButton2 then
        drag.active = true; drag.lastX = inp.Position.X; drag.lastY = inp.Position.Y
    end
    if inp.UserInputType == Enum.UserInputType.MouseWheel then
        viewState.zoom = math.clamp(viewState.zoom - inp.Position.Z * 2, viewState.minZoom, viewState.maxZoom)
        updateZoomHandle()
    end
end)
UserInputService.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton2 then drag.active = false end
end)
UserInputService.InputChanged:Connect(function(inp, gp)
    if gp or not viewState.target then return end
    if drag.active and inp.UserInputType == Enum.UserInputType.MouseMovement then
        local dx = inp.Position.X - drag.lastX; local dy = inp.Position.Y - drag.lastY
        drag.lastX = inp.Position.X; drag.lastY = inp.Position.Y
        viewState.yaw   = viewState.yaw - dx * drag.sensitivity
        viewState.pitch = math.clamp(viewState.pitch + dy * drag.sensitivity, viewState.minPitch, viewState.maxPitch)
    end
end)

-- ── MOBILE TOUCH ORBIT + PINCH ZOOM ─────────
local activeTouches = {}
local function isOverGui(pos)
    local guis = localPlayer.PlayerGui:GetGuiObjectsAtPosition(pos.X, pos.Y)
    for _, obj in ipairs(guis) do
        if obj ~= badge and obj ~= toastFrame and obj ~= toastLabel then return true end
    end
    return false
end
UserInputService.TouchStarted:Connect(function(touch, gp)
    if gp then return end
    activeTouches[touch.TouchId] = touch.Position
end)
UserInputService.TouchEnded:Connect(function(touch)
    activeTouches[touch.TouchId] = nil
    local count = 0; for _ in pairs(activeTouches) do count += 1 end
    if count < 2 then pinch.active = false end
end)
UserInputService.TouchMoved:Connect(function(touch, gp)
    if gp or not viewState.target then return end
    local prev = activeTouches[touch.TouchId]
    if not prev then return end
    local count = 0; for _ in pairs(activeTouches) do count += 1 end
    if count == 1 then
        if not isOverGui(touch.Position) then
            local dx = touch.Position.X - prev.X; local dy = touch.Position.Y - prev.Y
            viewState.yaw   = viewState.yaw - dx * drag.sensitivity
            viewState.pitch = math.clamp(viewState.pitch + dy * drag.sensitivity, viewState.minPitch, viewState.maxPitch)
        end
    elseif count == 2 then
        local ids = {}; for id in pairs(activeTouches) do table.insert(ids, id) end
        if #ids == 2 then
            local posA = (ids[1] == touch.TouchId) and touch.Position or activeTouches[ids[1]]
            local posB = (ids[2] == touch.TouchId) and touch.Position or activeTouches[ids[2]]
            local dist = (posA - posB).Magnitude
            if pinch.active then
                viewState.zoom = math.clamp(viewState.zoom + (pinch.lastDist - dist) * 0.05, viewState.minZoom, viewState.maxZoom)
                updateZoomHandle()
            else pinch.active = true end
            pinch.lastDist = dist
        end
    end
    activeTouches[touch.TouchId] = touch.Position
end)

-- ── COMMANDS ─────────────────────────────────
local function cmdView(args)
    if not args[2] then showToast("Usage: view <n>", Color3.fromRGB(255, 180, 50)); return end
    local target = findPlayer(args[2])
    if not target then showToast("❌ Player not found: " .. args[2], Color3.fromRGB(255, 80, 80)); return end
    if target == localPlayer then stopViewing(); return end
    startViewing(target)
end

local function cmdUnview()
    if viewState.target then stopViewing() else showToast("Not viewing anyone.", Color3.fromRGB(200, 200, 100)) end
end

local function cmdTp(args)
    if not args[2] then showToast("Usage: tp <n>", Color3.fromRGB(255, 180, 50)); return end
    local target = findPlayer(args[2])
    if not target then showToast("❌ Player not found: " .. args[2], Color3.fromRGB(255, 80, 80)); return end
    local root = getRoot(target)
    local myRoot = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
    if root and myRoot then
        myRoot.CFrame = root.CFrame + Vector3.new(2, 0, 0)
        showToast("✈ Teleported to " .. target.Name, Color3.fromRGB(80, 200, 255))
    else showToast("❌ Cannot teleport (missing character)", Color3.fromRGB(255, 80, 80)) end
end

local function cmdInfo(args)
    local target = (args[2] and findPlayer(args[2])) or viewState.target
    if not target then showToast("Usage: info <n>", Color3.fromRGB(255, 180, 50)); return end
    local char = target.Character
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    local root = getRoot(target)
    local hp    = hum  and math.floor(hum.Health)    or "?"
    local maxHp = hum  and math.floor(hum.MaxHealth) or "?"
    local pos   = root and string.format("%.0f, %.0f, %.0f", root.Position.X, root.Position.Y, root.Position.Z) or "unknown"
    local team  = target.Team and target.Team.Name or "None"
    infoBody.Text = string.format("Name: %s\nDisplay: %s\nHP: %s / %s\nTeam: %s\nPos: %s\nAcct Age: ~%d days",
        target.Name, target.DisplayName, hp, maxHp, team, pos, target.AccountAge)
    infoTitle.Text = "📋 " .. target.Name
    infoPanel.Visible = true
    showToast("ℹ Info for " .. target.Name, Color3.fromRGB(80, 200, 255))
end

local function cmdList()
    for _, child in ipairs(listScroll:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
    local plist = Players:GetPlayers()
    listScroll.CanvasSize = UDim2.new(0, 0, 0, #plist * 32)
    for _, p in ipairs(plist) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -6, 0, 28); btn.BackgroundColor3 = Color3.fromRGB(20, 25, 40)
        btn.TextColor3 = Color3.fromRGB(200, 220, 255); btn.Font = Enum.Font.GothamMedium
        btn.TextSize = 13; btn.Text = (p == localPlayer and "★ " or "   ") .. p.Name
        btn.TextXAlignment = Enum.TextXAlignment.Left; btn.BorderSizePixel = 0; btn.Parent = listScroll
        local bc = Instance.new("UICorner"); bc.CornerRadius = UDim.new(0,6); bc.Parent = btn
        local bp = Instance.new("UIPadding"); bp.PaddingLeft = UDim.new(0, 8); bp.Parent = btn
        btn.MouseButton1Click:Connect(function()
            listPanel.Visible = false
            if p ~= localPlayer then startViewing(p) end
        end)
    end
    listPanel.Visible = true
    showToast("👥 " .. #plist .. " player(s) online", Color3.fromRGB(80, 200, 255))
end

local function cmdZoom(args)
    local n = tonumber(args[2])
    if not n then showToast("Usage: zoom <1-50>", Color3.fromRGB(255, 180, 50)); return end
    viewState.zoom = math.clamp(n, viewState.minZoom, viewState.maxZoom)
    updateZoomHandle()
    showToast("🔍 Zoom set to " .. viewState.zoom, Color3.fromRGB(80, 200, 255))
end

