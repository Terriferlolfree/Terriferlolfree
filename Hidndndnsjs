local function handleInput(raw)
    raw = raw:match("^%s*(.-)%s*$")
    if raw == "" then return end
    local args = {}
    for w in raw:gmatch("%S+") do table.insert(args, w) end
    local fn = commands[args[1] and args[1]:lower()]
    if fn then fn(args) else showToast('Unknown: "' .. (args[1] or "") .. '". Try: help', Color3.fromRGB(255, 80, 80)) end
    textBox.Text = ""
end

textBox.FocusLost:Connect(function(enter) if enter then handleInput(textBox.Text) end end)

UserInputService.InputBegan:Connect(function(inp, gp)
    if gp then return end
    if inp.KeyCode == Enum.KeyCode.Return and not textBox:IsFocused() then textBox:CaptureFocus() end
end)

Players.PlayerRemoving:Connect(function(p)
    if p == viewState.target then stopViewing(); showToast("⚠ Viewed player left", Color3.fromRGB(255, 180, 50)) end
end)

